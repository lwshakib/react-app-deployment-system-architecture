# AWS Configuration
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1

# S3 Configuration
S3_BUCKET_NAME=project-files-123456

# Kafka Configuration (for log streaming)
KAFKA_BROKER=kafka-host:port
KAFKA_USERNAME=user
KAFKA_PASSWORD=password
KAFKA_CLIENT_ID=build-container
KAFKA_CA_CERT="-----BEGIN CERTIFICATE-----
...
-----END CERTIFICATE-----"

# Deployment Configuration (passed at runtime)
DEPLOYMENT_ID=test-123
GIT_REPOSITORY_URL=https://github.com/user/repo
