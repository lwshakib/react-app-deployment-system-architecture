{
  "name": "server",
  "version": "1.0.0",
  "description": "Deployment system backend server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node dist/index.js",
    "dev": "tsc-watch --onSuccess \"node dist/index.js\"",
    "build": "tsc -p .",
    "postgres:setup": "node dist/scripts/setup-postgres.js",
    "clickhouse:setup": "node dist/scripts/setup-clickhouse.js",
    "kafka:setup": "node dist/scripts/setup-kafka.js",
    "s3:setup": "node dist/scripts/setup-s3.js",
    "sqs:setup": "node dist/scripts/setup-sqs.js",
    "ecs:setup": "node dist/scripts/setup-ecs.js",
    "postgres:reset": "node dist/scripts/reset-postgres.js",
    "clickhouse:reset": "node dist/scripts/reset-clickhouse.js",
    "kafka:reset": "node dist/scripts/reset-kafka.js",
    "s3:reset": "node dist/scripts/reset-s3.js",
    "sqs:reset": "node dist/scripts/reset-sqs.js",
    "ecs:reset": "node dist/scripts/reset-ecs.js",
    "infra:setup": "pnpm postgres:setup && pnpm clickhouse:setup && pnpm kafka:setup && pnpm s3:setup && pnpm sqs:setup && pnpm ecs:setup",
    "infra:reset": "pnpm ecs:reset && pnpm sqs:reset && pnpm s3:reset && pnpm kafka:reset && pnpm clickhouse:reset && pnpm postgres:reset",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1019.0",
    "@aws-sdk/client-ec2": "^3.1019.0",
    "@aws-sdk/client-ecr": "^3.1019.0",
    "@aws-sdk/client-ecs": "^3.1019.0",
    "@aws-sdk/client-iam": "^3.1019.0",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/client-sqs": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@clickhouse/client": "^1.18.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "random-word-slugs": "^0.1.7",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^11.0.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.7.3"
  }
}
