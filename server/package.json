{
  "name": "server",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc",
    "start": "bun run dist/index.js",
    "postgres:setup": "bun run src/scripts/setup-postgres.ts",
    "clickhouse:setup": "bun run src/scripts/setup-clickhouse.ts",
    "kafka:setup": "bun run src/scripts/setup-kafka.ts",
    "s3:setup": "bun run src/scripts/setup-s3.ts",
    "sqs:setup": "bun run src/scripts/setup-sqs.ts",
    "ecs:setup": "bun run src/scripts/setup-ecs.ts",
    "postgres:reset": "bun run src/scripts/reset-postgres.ts",
    "clickhouse:reset": "bun run src/scripts/reset-clickhouse.ts",
    "kafka:reset": "bun run src/scripts/reset-kafka.ts",
    "s3:reset": "bun run src/scripts/reset-s3.ts",
    "sqs:reset": "bun run src/scripts/reset-sqs.ts",
    "ecs:reset": "bun run src/scripts/reset-ecs.ts",
    "infra:setup": "bun run postgres:setup && bun run clickhouse:setup && bun run kafka:setup && bun run s3:setup && bun run sqs:setup && bun run ecs:setup",
    "infra:reset": "bun run ecs:reset && bun run sqs:reset && bun run s3:reset && bun run kafka:reset && bun run clickhouse:reset && bun run postgres:reset"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^11.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1019.0",
    "@aws-sdk/client-ec2": "^3.1019.0",
    "@aws-sdk/client-ecr": "^3.1019.0",
    "@aws-sdk/client-ecs": "^3.1019.0",
    "@aws-sdk/client-iam": "^3.1019.0",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/client-sqs": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@clickhouse/client": "^1.18.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.20.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "random-word-slugs": "^0.1.7",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
