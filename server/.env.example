# Server Configuration
PORT=8000
NODE_ENV=production

# PostgreSQL (Aiven / EC2)
DATABASE_URL=postgres://user:password@host:port/database
POSTGRES_CA_CERT="-----BEGIN CERTIFICATE-----
... (Your PostgreSQL CA Certificate) ...
-----END CERTIFICATE-----"

# AWS General
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# Kafka (Aiven / Upstash)
KAFKA_BROKER=kafka-host:port
KAFKA_USERNAME=user
KAFKA_PASSWORD=password
KAFKA_CLIENT_ID=deployment-service
KAFKA_CA_CERT="-----BEGIN CERTIFICATE-----
... (Your Kafka CA Certificate) ...
-----END CERTIFICATE-----"

# ClickHouse (Analytics)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DB=analytics

# Storage
S3_BUCKET_NAME=project-files-123456

# [MANUALLY ADDED - Networking]
S3_REVERSE_PROXY_URL=http://localhost:8080

# [AUTOMATED - SQS]
AWS_SQS_QUEUE_URL='https://sqs.ap-south-1.amazonaws.com/YOUR_ACCOUNT_ID/YOUR_QUEUE_NAME'

# [AUTOMATED - ECS]
ECS_CLUSTER_ARN='arn:aws:ecs:ap-south-1:YOUR_ACCOUNT_ID:cluster/YOUR_CLUSTER_NAME'
ECS_TASK_DEFINITION_ARN='arn:aws:ecs:ap-south-1:YOUR_ACCOUNT_ID:task-definition/YOUR_TASK_NAME:REVISION'
ECS_CONTAINER_NAME='build-container'
ECS_SUBNETS='subnet-...,subnet-...'
ECS_SECURITY_GROUPS='sg-...'
