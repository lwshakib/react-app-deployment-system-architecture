# AWS Infrastructure Configuration
# The name of the S3 bucket where build artifacts are stored
S3_BUCKET_NAME=your-bucket-name
# The target AWS region for S3 operations
AWS_REGION=ap-south-1

# Server Configuration
# The local port the reverse proxy will listen on
PORT=8080

# Database Configuration (PostgreSQL)
# Full connection string for the primary relational database
DATABASE_URL=postgres://user:password@hostname:port/dbname

# SSL/TLS Certificate for secure database communication
# Paste your raw CA certificate string here
POSTGRES_CA_CERT="your-ca-certificate-string"
